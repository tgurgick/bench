# Copy to .env and fill in real values — .env is gitignored.
# Loaded automatically by the npm scripts (node --env-file-if-exists=.env).
# For a bare `bench` CLI call, either run via npm scripts or: set -a; source .env; set +a
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Google AI Studio key for the gemini provider
GEMINI_API_KEY=
# optional: fallback model when a cell omits model: (e.g. gemini-2.5-flash)
GEMINI_MODEL=
# optional: any OpenAI-compatible endpoint (e.g. a local server)
BENCH_OPENAI_BASE_URL=
